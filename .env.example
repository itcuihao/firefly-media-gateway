# ===============================
# 服务配置
# ===============================
APP_LISTEN_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080
MEDIA_GATEWAY_TOKEN=replace_with_strong_token

# ===============================
# 数据库配置
# ===============================
DATABASE_URL=postgres://media:media_password@postgres:5432/media_gateway?sslmode=disable

# ===============================
# 存储模式选择
# ===============================
# direct: 直连 Telegram（需要下面 Telegram 配置）
# proxy: 通过 Cloudflare Workers 代理（需要下面 Worker 配置）
STORAGE_MODE=direct

# ===============================
# Telegram 配置（Direct 模式）
# ===============================
# 方式一：单 Bot 配置
TELEGRAM_BOT_TOKEN=replace_with_tg_bot_token
TELEGRAM_CHAT_ID=replace_with_chat_id

# 方式二：多 Bot 配置（JSON 格式，优先级高于单 Bot）
# TELEGRAM_BOTS_CONFIG={"bot1":{"token":"xxx","default_group":"-100xxx"},"bot2":{"token":"yyy","default_group":"-100yyy"}}

# ===============================
# Worker 配置（Proxy 模式）
# ===============================
# WORKER_BASE_URL=https://your-worker.workers.dev
# WORKER_AUTH_TOKEN=replace_with_worker_auth_token

# ===============================
# 访问控制与私有资源规则配置
# ===============================
# 逗号分隔的私有资源规则列表，定义哪些媒体文件需要鉴权（Bearer Token 或 URL 预签名）访问：
# 1. 留空（不配置）：全局公开访问，所有媒体资源均可公开读取（图床/公开媒体网关推荐）
# 2. 配置为 * 或 all：全局私有访问，所有媒体资源均需要鉴权才能读取
# 3. 配置为特定标识符（例如 interactive-video,scene,secret）：
#    若媒体文件的项目名（Project）或用途（Usage）包含在列表中，则该文件为私有（需要鉴权）；其他文件仍公开。
PRIVATE_RULES=interactive-video,scene,secret

# ===============================
# 其他配置
# ===============================
MEDIA_PROVIDER_DEFAULT=tg
UPLOAD_TIMEOUT_SECONDS=60
